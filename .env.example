# Primary Gemini API key (required)
GEMINI_API_KEY=your_key_here

# Optional: add keys from 3 more separate GCP projects for key rotation
# Creating multiple keys in the SAME project gives NO extra quota
GEMINI_KEY_2=key_from_gcp_project_2
GEMINI_KEY_3=key_from_gcp_project_3
GEMINI_KEY_4=key_from_gcp_project_4

# Databricks (leave false for demo mode)
DATABRICKS_ENABLED=false
