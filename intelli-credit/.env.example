# Environment variables for Intelli-Credit
# Copy to .env and fill in your keys

# Primary Gemini key (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Additional keys from separate GCP projects (optional but recommended)
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=

# Databricks integration (optional — set to true to enable)
DATABRICKS_ENABLED=false
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<personal-access-token>
DATABRICKS_CATALOG=intelli_credit
DATABRICKS_WAREHOUSE_ID=<sql-warehouse-id>
